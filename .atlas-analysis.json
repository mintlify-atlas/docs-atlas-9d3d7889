  "keyFeatures": [
    "Ultra-fast in-memory database with array-based columns",
    "Big-data support for billions of cells",
    "Multi-platform (VCL, FireMonkey, Lazarus)",
    "SQL-like query engine with summaries and group-by",
    "Excel-like pivot tables with drag & drop editor",
    "Import from CSV, JSON, XML, databases, Excel, AI agents",
    "Export to multiple formats (CSV, PDF, HTML, XML, Excel, JSON)",
    "Automatic visualizations (charts, grids, trees)",
    "Geographic database with world maps and statistics",
    "Master-detail relationships and automatic indexing"
  ],
  "publicApiSurface": [
    "TDataItem - Core data structure class",
    "TDataKind - Data type enumeration",
    "TBISQL - SQL query parser and executor",
    "TBIQuery - Component for queries and summaries",
    "TSummary - Aggregation and group-by operations",
    "TBICSV - CSV import/export",
    "TBIJson - JSON import/export",
    "TBIDB - Database import",
    "TBIXML - XML import/export",
    "TBIAI - AI agent import",
    "TBIGrid - Grid visualization component",
    "TBIChart - Chart visualization component",
    "TExpression - Expression engine",
    "TAggregate - Aggregation functions",
    "TDataSelect - Select query operations",
    "TBICompare - Data comparison utilities",
    "TBIConvert - Data conversion utilities",
    "TBIMerge - Data merging operations",
    "TBISearch - Search functionality"
  ]
